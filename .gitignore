# ——— CRITICAL: secrets ———
# backend/.env contains:
#   DATABASE_URL (DB password)
#   JWT_SECRET_KEY / CSRF_SECRET_KEY (auth tokens)
#   MAIL_PASSWORD (SMTP credentials)
# NEVER commit this file.
