DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/tracklog
JWT_SECRET_KEY=key
CSRF_SECRET_KEY=key
COOKIE_SECURE=false
CSRF_ENABLED=false
CELERY_TASK_ALWAYS_EAGER=true
RATE_LIMIT_ENABLED=false
UPLOAD_DIR=/tmp/gps_tracker_uploads

# Comma-separated list of frontend origins allowed to call the API.
# MUST be the public origin(s) the user sees in their browser bar.
# Add the production URL when deploying, e.g.:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public base URL of the FRONTEND.
# This is what gets baked into verification emails and any other
# user-facing links the backend generates (e.g. password reset).
# MUST be the public URL the user sees in their browser bar —
# not the API URL, not 127.0.0.1. When you deploy, change this.
APP_BASE_URL=http://localhost:5173

# ====================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# When APP_BASE_URL is set to anything other than http://localhost
# or http://127.0.0.1, the app refuses to start with the following
# insecure defaults. Override each one before going live:
#
#   APP_BASE_URL     — your public frontend URL
#   CORS_ORIGINS     — same (or comma-separated list of allowed origins)
#   COOKIE_SECURE    — set to true (HTTPS-only cookies)
#   CSRF_ENABLED     — set to true
#   RATE_LIMIT_ENABLED — set to true
#   JWT_SECRET_KEY   — long random string, 64+ chars recommended
#   CSRF_SECRET_KEY  — long random string, 64+ chars recommended
#   MAIL_TLS_VERIFY  — set to true once your SMTP cert is renewed
#
# To generate a secret:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# ====================================================================

# Email verification (SMTP)
# Mail goes out via the SMTP server below. The MAIL_PASSWORD is
# the only secret here — never commit .env to source control.
MAIL_ENABLED=true
MAIL_HOST=mail.ru
MAIL_PORT=587
MAIL_USERNAME=username
MAIL_PASSWORD=password
MAIL_FROM=noreply@mail.ru
MAIL_DEV_OUT_DIR=/tmp/verification_emails
# Dev escape hatch: the cert on mail.theswap.online is currently
# expired. Set to false to skip TLS verification. Do NOT do this
# in production — it makes MITM trivial.
MAIL_TLS_VERIFY=false
